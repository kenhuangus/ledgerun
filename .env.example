# ---- App database (our Prisma Postgres) ----
# Local dev points at the app-db service on :5432.
DATABASE_URL="postgresql://ledgerun:ledgerun@localhost:5432/ledgerun?schema=public"

# ---- Reference API (read-only canonical data; reached ONLY via the MCP server) ----
# The MCP server holds this; the app/orchestrator never calls it directly.
REFERENCE_API_URL="http://localhost:8000"

# ---- LLM (Anthropic / Claude) ----
ANTHROPIC_API_KEY="sk-ant-..."
# Model id is swappable behind the LlmClient interface.
ANTHROPIC_MODEL="claude-opus-4-8"

# ---- MCP server ----
# How the app's MCP client reaches the MCP server. "stdio" spawns it as a child
# process (default for local dev); "http" connects to a running server.
MCP_TRANSPORT="stdio"
MCP_SERVER_URL="http://localhost:7000"

# ---- Ingestion ----
# DropFolderSource watches this directory for invoice files.
DROP_FOLDER="./.drop"
# Where ingested raw blobs are stored.
UPLOAD_DIR="./uploads"

# ---- Decision policy overrides (optional; defaults live in src/config) ----
# POLICY_HIGH_CONFIDENCE=0.85
# POLICY_LOW_CONFIDENCE=0.60
# POLICY_PRICE_PCT_TOLERANCE=0.02
# POLICY_PRICE_ABS_TOLERANCE=25
# POLICY_MAX_LOW_CONFIDENCE_AUTO_SUBMIT=0

# ---- Logging ----
LOG_LEVEL="info"
