    "mailparser": "^3.9.9",
    "next": "^14.2.18",
    "pdfjs-dist": "^4.10.38",
    "pino": "^9.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "pino-pretty": "^13.0.0",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
